{
  "manifest_version": 3,
  "name": "Gemini Usage Tracker",
  "version": "1.0.0",
  "description": "Displays your daily and weekly Google Gemini usage in a stunning Material Design interface.",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "offscreen",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://gemini.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/usage*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  }
}